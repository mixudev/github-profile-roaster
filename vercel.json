{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/github/:username", "destination": "/api/github/[username]" },
    { "source": "/api/(.*)",             "destination": "/api/$1" },
    { "source": "/(.*)",                 "destination": "/index.html" }
  ],
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 30,
      "includeFiles": "server/**"
    }
  }
}
