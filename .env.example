# ============================================================
# GITHUB PROFILE ROASTER - Environment Configuration
# ============================================================

# --- AI PROVIDER SELECTION ---
# Choose which AI provider to use as primary: gemini | grok | openrouter | openai
AI_PROVIDER="gemini"

# --- GEMINI API KEYS (Google) ---
# Add multiple keys separated by commas for auto-rotation on rate limit
GEMINI_API_KEY="your_gemini_api_key_1,your_gemini_api_key_2"
GEMINI_MODEL="gemini-2.0-flash"

# --- GROK API KEYS (xAI) ---
# Add multiple keys separated by commas for auto-rotation on rate limit
GROK_API_KEY="your_grok_api_key_1,your_grok_api_key_2"
GROK_MODEL="grok-3-mini"

# --- OPENROUTER API KEYS ---
# Add multiple keys separated by commas for auto-rotation on rate limit
OPENROUTER_API_KEY="your_openrouter_api_key_1"
OPENROUTER_MODEL="meta-llama/llama-3.3-8b-instruct:free"

# --- OPENAI API KEYS ---
# Add multiple keys separated by commas for auto-rotation on rate limit
OPENAI_API_KEY="your_openai_api_key_1"
OPENAI_MODEL="gpt-4o-mini"

# --- GITHUB API TOKEN (optional but recommended) ---
# Increases rate limit from 60 to 5000 requests/hour
GITHUB_TOKEN="your_github_personal_access_token"

# --- APP ---
APP_URL="http://localhost:3000"
PORT=3000
